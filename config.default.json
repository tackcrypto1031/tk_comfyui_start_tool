{
  "default_env": "main",
  "python_path": null,
  "comfyui_repo_url": "https://github.com/comfyanonymous/ComfyUI.git",
  "base_dir": ".",
  "environments_dir": "./environments",
  "models_dir": "./models",
  "snapshots_dir": "./snapshots",
  "max_snapshots": 20,
  "auto_snapshot": true,
  "auto_open_browser": true,
  "pytorch_index_url": "https://download.pytorch.org/whl/cu124",
  "default_port": 8188,
  "theme": "dark",
  "language": "zh-TW",
  "color_scheme": "tack-industrial",
  "log_level": "INFO",
  "model_subdirs": [
    "checkpoints",
    "loras",
    "vae",
    "controlnet",
    "clip",
    "embeddings",
    "upscale_models",
    "audio_encoders",
    "clip_vision",
    "configs",
    "diffusers",
    "diffusion_models",
    "gligen",
    "hypernetworks",
    "latent_upscale_models",
    "model_patches",
    "photomaker",
    "seethrough",
    "style_models",
    "text_encoders",
    "unet",
    "vae_approx",
    "test_model",
    "llm",
    "ultralytics",
    "yolo",
    "onnx",
    "sams"
  ],
  "conflict_analyzer": {
    "critical_packages": [
      "torch",
      "torchvision",
      "torchaudio",
      "numpy",
      "scipy",
      "transformers",
      "safetensors",
      "Pillow",
      "xformers",
      "opencv-python",
      "opencv-python-headless",
      "accelerate",
      "onnxruntime",
      "onnxruntime-gpu"
    ],
    "auto_analyze_on_install": true
  },
  "shared_model_mode": "default",
  "custom_model_path": "",
  "package_manager": "uv",
  "ui_flags": {}
}
